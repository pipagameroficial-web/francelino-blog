<!DOCTYPE html>
<html lang="pt-BR">
<head>
    {% if settings.gtm_id %}
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','{{ settings.gtm_id }}');</script>
    <!-- End Google Tag Manager -->
    {% endif %}

    {% if settings.google_analytics_id %}
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.google_analytics_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.google_analytics_id }}');
    </script>
    <!-- End Google Analytics -->
    {% endif %}

    {% if settings.google_verification %}
    <!-- Verificação do Google Search Console -->
    <meta name="google-site-verification" content="{{ settings.google_verification }}" />
    {% endif %}

    <!-- Netlify Identity (Login) -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Francelino Turismo | A Sua Agência de Viagens</title>
    <link rel="stylesheet" href="/agencia-style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    {% if settings.gtm_id %}
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ settings.gtm_id }}"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    {% endif %}

    <!-- Header -->
    <header class="header" id="header">
        <div class="header-dark-bg">
            <div class="header-dark-content">
                <a href="#" class="logo-new">
                    <i class="fa-solid fa-plane-departure" style="font-size: 2rem;"></i>
                    <div class="logo-text">
                        <span>FRANCELINO</span> TURISMO<br>
                        <small>| AGÊNCIA DE VIAGENS</small>
                    </div>
                </a>
                
                <nav class="nav-menu" id="nav-menu">
                    <ul class="nav-list">
                        <li><a href="#aereos" class="nav-link"><i class="fa-solid fa-plane" style="transform: rotate(-45deg);"></i> Aéreos</a></li>
                        <li><a href="#rodoviarios" class="nav-link"><i class="fa-solid fa-bus"></i> Rodoviários</a></li>
                        <li><a href="#cruzeiros" class="nav-link"><i class="fa-solid fa-ship"></i> Cruzeiros</a></li>
                        <li><a href="#servicos" class="nav-link"><i class="fa-solid fa-address-card"></i> Serviços</a></li>
                        <li><a href="/promocao/" class="nav-link"><i class="fa-solid fa-tag"></i> Promoções</a></li>
                    </ul>
                </nav>
            </div>
        </div>
        
        <div class="header-actions">
            <div class="nav-search">
                <input type="text" placeholder="Buscar destino ou pacote...">
                <button><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
            <a href="https://wa.me/{{ settings.whatsapp }}" class="header-wa-btn" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
            
            <div class="mobile-toggle" id="mobile-toggle">
                <i class="fa-solid fa-bars"></i>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero">
        <img src="/agencia-hero.png" alt="Cenário Paradisíaco" class="hero-bg" fetchpriority="high">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <h1>Descubra o Mundo com <span>Conforto e Segurança</span></h1>
            <p>Os melhores pacotes aéreos, rodoviários e cruzeiros para a sua próxima aventura inesquecível.</p>
            
            <div class="hero-search-box">
                <form class="search-form">
                    <div class="input-group">
                        <i class="fa-solid fa-location-dot"></i>
                        <input type="text" placeholder="Para onde você quer ir?">
                    </div>
                    <div class="input-group">
                        <i class="fa-regular fa-calendar-days"></i>
                        <input type="text" placeholder="Quando?">
                    </div>
                    <button type="submit" class="btn btn-primary">Buscar Pacotes</button>
                </form>
            </div>
        </div>
    </section>


    <!-- Seção de Aéreos -->
    <section id="aereos" class="section">
        <div class="container">
            <div class="section-header">
                <h2><i class="fa-solid fa-plane-up"></i> Pacotes Aéreos</h2>
                <p>As melhores tarifas e destinos internacionais preparados para você.</p>
            </div>
            
            <div class="grid cards-grid">
                {% for pacote in collections.pacotes_aereos %}
                <div class="package-card">
                    <div class="card-img-wrapper">
                        <img src="{{ pacote.data.image | optimize_unsplash(800) }}" alt="{{ pacote.data.title }}" loading="lazy">
                        {% if pacote.data.badge.text %}
                        <span class="badge badge-{{ pacote.data.badge.color | lower }}" style="max-width: 90%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ pacote.data.badge.text }}
                        </span>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <h3>{{ pacote.data.title }}</h3>
                        <div class="card-info">
                            <span><i class="fa-regular fa-calendar"></i> {{ pacote.data.dates.display | default(pacote.data.date_range) }}</span>
                            <span><i class="fa-solid fa-clock"></i> {{ pacote.data.duration }}</span>
                        </div>
                        <p class="destination"><i class="fa-solid fa-location-dot"></i> {{ pacote.data.location }}</p>
                        <div class="price-box">
                            <span class="price-label">A partir de</span>
                            <span class="price-value">R$ {{ pacote.data.price }}</span>
                            <span class="price-cond">{{ pacote.data.price_cond }}</span>
                        </div>
                        <a href="{{ pacote.url }}" class="btn btn-outline btn-full">Saiba Mais</a>
                    </div>
                </div>
                {% else %}
                <p style="text-align: center; grid-column: 1/-1;">Nenhum pacote aéreo disponível no momento.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Pacotes Rodoviários -->
    <section id="rodoviarios" class="section bg-light">
        <div class="container">
            <div class="section-header">
                <h2><i class="fa-solid fa-bus-simple"></i> Pacotes Rodoviários</h2>
                <p>Conforto e segurança pelas melhores rodovias em nossos ônibus modernos.</p>
            </div>
            
            <div class="grid cards-grid">
                {% for pacote in collections.pacotes_rodoviarios %}
                <div class="package-card">
                    <div class="card-img-wrapper">
                        <img src="{{ pacote.data.image | optimize_unsplash(800) }}" alt="{{ pacote.data.title }}" loading="lazy">
                        {% if pacote.data.badge.text %}
                        <span class="badge badge-{{ pacote.data.badge.color | lower }}" style="max-width: 90%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ pacote.data.badge.text }}
                        </span>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <h3>{{ pacote.data.title }}</h3>
                        <div class="card-info">
                            <span><i class="fa-regular fa-calendar"></i> {{ pacote.data.dates.display | default(pacote.data.date_range) }}</span>
                            <span><i class="fa-solid fa-clock"></i> {{ pacote.data.duration }}</span>
                        </div>
                        <p class="destination"><i class="fa-solid fa-location-dot"></i> {{ pacote.data.location }}</p>
                        <div class="price-box">
                            <span class="price-label">A partir de</span>
                            <span class="price-value">R$ {{ pacote.data.price }}</span>
                            <span class="price-cond">{{ pacote.data.price_cond }}</span>
                        </div>
                        <a href="{{ pacote.url }}" class="btn btn-outline btn-full">Saiba Mais</a>
                    </div>
                </div>
                {% else %}
                <p style="text-align: center; grid-column: 1/-1;">Nenhum pacote rodoviário disponível no momento.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Cruzeiros -->
    <section id="cruzeiros" class="section">
        <div class="container">
            <div class="section-header">
                <h2><i class="fa-solid fa-ship"></i> Cruzeiros</h2>
                <p>Navegue por águas nacionais e internacionais com luxo e all-inclusive.</p>
            </div>
            
            <div class="grid cards-grid">
                {% for pacote in collections.cruzeiros %}
                <div class="package-card">
                    <div class="card-img-wrapper">
                        <img src="{{ pacote.data.image | optimize_unsplash(800) }}" alt="{{ pacote.data.title }}" loading="lazy">
                        {% if pacote.data.badge.text %}
                        <span class="badge badge-{{ pacote.data.badge.color | lower }}" style="max-width: 90%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                            {{ pacote.data.badge.text }}
                        </span>
                        {% endif %}
                    </div>
                    <div class="card-body">
                        <h3>{{ pacote.data.title }}</h3>
                        <div class="card-info">
                            <span><i class="fa-solid fa-anchor"></i> {{ pacote.data.itinerary }}</span>
                            <span><i class="fa-solid fa-clock"></i> {{ pacote.data.duration }}</span>
                        </div>
                        <div class="price-box">
                            <span class="price-label">A partir de</span>
                            <span class="price-value">R$ {{ pacote.data.price }}</span>
                            <span class="price-cond">{{ pacote.data.price_cond }}</span>
                        </div>
                        <a href="{{ pacote.url }}" class="btn btn-outline btn-full">Saiba Mais</a>
                    </div>
                </div>
                {% else %}
                <p style="text-align: center; grid-column: 1/-1;">Nenhum cruzeiro disponível no momento.</p>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Frota -->
    <section id="frota" class="section fleet-section">
        <div class="container">
            <div class="grid fleet-grid">
                <div class="fleet-content">
                    <h2>Conheça nossa <span>Frota VIP</span></h2>
                    <p>Viaje com o máximo de conforto, segurança e pontualidade. Nossos veículos passam por rigorosas manutenções para garantir a melhor experiência na estrada.</p>
                    <ul class="fleet-features">
                        <li><i class="fa-solid fa-check"></i> Ônibus Leito e Semi-Leito</li>
                        <li><i class="fa-solid fa-check"></i> Wi-Fi, USB e Ar Condicionado</li>
                        <li><i class="fa-solid fa-check"></i> Assentos reclináveis ergonômicos (até 42 lugares)</li>
                        <li><i class="fa-solid fa-check"></i> Rastreadores de última geração</li>
                    </ul>
                    <a href="#contato" class="btn btn-primary">Solicitar Cotação para Grupos</a>
                </div>
                <div class="fleet-image">
                    <img src="/agencia-bus.png" alt="Nossa Frota" loading="lazy">
                    <div class="fleet-card-float">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Viagem Segura Garantida</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Serviços Adicionais -->
    <section id="servicos" class="section bg-light">
        <div class="container">
            <div class="section-header">
                <h2><i class="fa-solid fa-briefcase"></i> Serviços Adicionais</h2>
                <p>Tudo o que você precisa para uma viagem sem preocupações, em um só lugar.</p>
            </div>
            
            <div class="grid services-grid">
                <div class="service-item">
                    <div class="service-icon"><i class="fa-solid fa-passport"></i></div>
                    <h3>Passaportes e Vistos</h3>
                    <p>Assessoria completa para emissão ou renovação de passaporte e vistos consulares.</p>
                    <a href="#" class="btn btn-sm btn-outline">Contratar</a>
                </div>
                
                <div class="service-item">
                    <div class="service-icon"><i class="fa-solid fa-car"></i></div>
                    <h3>Aluguel de Carros</h3>
                    <p>Parcerias com as melhores locadoras para você ter liberdade no seu destino.</p>
                    <a href="#" class="btn btn-sm btn-outline">Contratar</a>
                </div>

                <div class="service-item">
                    <div class="service-icon"><i class="fa-solid fa-house-medical"></i></div>
                    <h3>Seguro Viagem</h3>
                    <p>Viaje protegido contra imprevistos de saúde e bagagem extraviada.</p>
                    <a href="#" class="btn btn-sm btn-outline">Contratar</a>
                </div>

                <div class="service-item">
                    <div class="service-icon"><i class="fa-solid fa-ticket"></i></div>
                    <h3>Ingressos Disney & Parques</h3>
                    <p>Compre ingressos antecipados para os principais parques temáticos do mundo.</p>
                    <a href="#" class="btn btn-sm btn-outline">Contratar</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Parceiros -->
    <section id="parceiros" class="section">
        <div class="container">
            <div class="section-header">
                <h2>Nossos Parceiros</h2>
            </div>
            <div class="partners-logo-wrap">
                <!-- Mock Partner Logos with FontAwesome inside circles or text -->
                <div class="partner-logo"><span class="partner-text">LATAM</span></div>
                <div class="partner-logo"><span class="partner-text">GOL</span></div>
                <div class="partner-logo"><span class="partner-text">AZUL</span></div>
                <div class="partner-logo"><span class="partner-text">MSC CRUZEIROS</span></div>
                <div class="partner-logo"><span class="partner-text">COSTA</span></div>
                <div class="partner-logo"><span class="partner-text">LOCALIZA</span></div>
            </div>
        </div>
    </section>

    <!-- WhatsApp CTA Full Width -->
    <section class="whatsapp-cta-section">
        <div class="container whatsapp-container">
            <div class="wa-content">
                <h2>Receba Ofertas Exclusivas no seu WhatsApp!</h2>
                <p>Junte-se ao nosso grupo VIP e seja o primeiro a saber das melhores promoções, passagens imperdíveis e pacotes de última hora.</p>
                <a href="https://wa.me/{{ settings.whatsapp }}" class="btn btn-wa-large" target="_blank"><i class="fa-brands fa-whatsapp"></i> Entrar no Grupo VIP</a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer" id="contato">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col brand-col">
                    <a href="#" class="footer-logo">
                        <i class="fa-solid fa-plane-departure"></i> Francelino<span>Turismo</span>
                    </a>
                    <p>A sua agência de confiança para transformar seus sonhos de viagem em realidade, com segurança e preços imperdíveis.</p>
                    <div class="social-links">
                        <a href="#"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="https://wa.me/{{ settings.whatsapp }}" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
                    </div>
                </div>

                <div class="footer-col">
                    <h4>Links Rápidos</h4>
                    <ul>
                        <li><a href="#aereos">Pacotes Aéreos</a></li>
                        <li><a href="#rodoviarios">Excursões Rodoviárias</a></li>
                        <li><a href="#cruzeiros">Cruzeiros</a></li>
                        <li><a href="#servicos">Serviços Adicionais</a></li>
                    </ul>
                </div>

                <div class="footer-col contact-col">
                    <h4>Contato</h4>
                    <ul>
                        <li><i class="fa-solid fa-location-dot"></i> Av. das Viagens, 1234 - Centro</li>
                        <li><i class="fa-solid fa-phone"></i> (11) 9999-9999</li>
                        <li><i class="fa-brands fa-whatsapp"></i> {{ settings.whatsapp }}</li>
                        <li><i class="fa-solid fa-envelope"></i> reservas@viajamundo.com.br</li>
                    </ul>
                </div>
            </div>
            
            <div class="footer-bottom">
                <p>&copy; 2026 Francelino Turismo Agência de Viagens - Todos os direitos reservados. Confie na nossa agência!</p>
            </div>
        </div>
    </footer>

    <!-- Floating WhatsApp Button -->
    <a href="https://wa.me/{{ settings.whatsapp }}" class="floating-wa" aria-label="WhatsApp" target="_blank">
        <i class="fa-brands fa-whatsapp"></i>
    </a>

    <script src="/agencia-main.js"></script>

    <!-- Netlify Identity Script -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
        // ESTA É A CHAVE MESTRA:
        window.netlifyIdentity.setAPIUrl('https://monumental-profiterole-1a8105.netlify.app/.netlify/identity');
        window.netlifyIdentity.setLocale('pt');
      }
    </script>

</body>
</html>
