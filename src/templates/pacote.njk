<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Francelino Turismo</title>
    
    <link rel="stylesheet" href="/agencia-style.css?v=4.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-navy: #1A1A1A;
            --accent-orange: #F89C1D;
            --success-green: #00D136;
            --bg-gray: #F4F7F6;
            --text-gray: #666666;
            --white: #FFFFFF;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-gray);
            margin: 0;
            color: #333;
        }

        .header-top {
            background: #1A1A1A;
            color: white;
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .main-layout {
            max-width: 1200px;
            margin: 40px auto;
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 40px;
            padding: 0 20px;
        }

        /* Galeria Estilo Gadotti */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin: 25px 0 40px;
        }

        .gallery-item {
            aspect-ratio: 4/3;
            border-radius: 8px;
            overflow: hidden;
            background: #eee;
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Sidebar Info Box */
        .info-sidebar {
            background: white;
            border-radius: 20px;
            padding: 35px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            position: sticky;
            top: 100px;
        }

        .date-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid #EEE;
        }

        .date-item span {
            display: block;
            font-size: 0.75rem;
            color: #999;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .date-item strong {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }

        .price-section {
            margin: 30px 0;
        }

        .price-section .label { font-size: 0.9rem; color: #666; }
        .price-section .value { 
            display: block; 
            font-size: 2.2rem; 
            font-weight: 800; 
            color: #1A1A1A; 
            margin: 5px 0;
        }

        .btn-comprar {
            display: block;
            background: var(--success-green);
            color: white;
            text-align: center;
            padding: 20px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.2rem;
            transition: transform 0.2s ease, background 0.2s ease;
        }

        .btn-comprar:hover {
            transform: translateY(-3px);
            background: #00B52F;
        }

        .itinerary-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            margin-bottom: 40px;
        }

        .footer-premium {
            background: #FFFFFF;
            padding: 80px 0 40px;
            border-top: 1px solid #EEE;
            margin-top: 80px;
        }

        @media (max-width: 992px) {
            .main-layout { grid-template-columns: 1fr; }
            .gallery-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>

    <header class="header-top">
        <div class="container-wide">
            <a href="/" style="color: white; text-decoration: none; font-weight: 800; font-size: 1.4rem;">
                FRANCELINO <span style="color: var(--accent-orange);">TURISMO</span>
            </a>
            <div style="display: flex; gap: 20px; align-items: centre;">
                <div style="background: rgba(255,255,255,0.1); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem;">
                    Buscar destino... <i class="fa-solid fa-magnifying-glass"></i>
                </div>
                <a href="https://wa.me/{{ settings.whatsapp }}" style="color: white; font-size: 1.5rem;"><i class="fa-brands fa-whatsapp"></i></a>
            </div>
        </div>
    </header>

    <main class="main-layout">
        <div class="content-main">
            <div style="font-size: 0.85rem; color: #999; margin-bottom: 20px;">
                Home • Pacotes • {{ category | default('Nacional') }}
            </div>
            
            <h1 style="font-size: 2.5rem; margin-bottom: 10px;">{{ title }}</h1>
            <div style="background: #1A1A1A; color: white; display: inline-block; padding: 4px 15px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">
                <i class="fa-solid fa-tags"></i> {{ category | default('Nacional') }}
            </div>

            <div class="gallery-grid">
                <div class="gallery-item"><img src="{{ gallery.img1 | default(image) }}" alt="Foto 1"></div>
                <div class="gallery-item"><img src="{{ gallery.img2 | default(image) }}" alt="Foto 2"></div>
                <div class="gallery-item"><img src="{{ gallery.img3 | default(image) }}" alt="Foto 3"></div>
                <div class="gallery-item"><img src="{{ gallery.img4 | default(image) }}" alt="Foto 4"></div>
                <div class="gallery-item"><img src="{{ gallery.img5 | default(image) }}" alt="Foto 5"></div>
                <div class="gallery-item"><img src="{{ gallery.img6 | default(image) }}" alt="Foto 6"></div>
            </div>

            <div class="itinerary-card">
                <h2 style="font-size: 1.6rem; border-bottom: 2px solid #F4F7F6; padding-bottom: 15px; margin-bottom: 25px;">Detalhes do Pacote</h2>
                <div style="line-height: 1.8; font-size: 1.1rem;">
                    {{ content | safe }}
                </div>
            </div>
        </div>

        <aside class="sidebar-info">
            <div class="info-sidebar">
                <h3 style="margin-top: 0; font-size: 1.4rem; margin-bottom: 25px;">Informações</h3>
                
                <div class="date-row">
                    <div class="date-item">
                        <span>SAÍDA</span>
                        <strong><i class="fa-regular fa-calendar" style="color: var(--accent-orange);"></i> {{ dates.departure | default('Consultar') }}</strong>
                    </div>
                    <div class="date-item">
                        <span>RETORNO</span>
                        <strong><i class="fa-regular fa-calendar" style="color: var(--accent-orange);"></i> {{ dates.return | default('Consultar') }}</strong>
                    </div>
                </div>

                <div class="price-section">
                    <span class="label">A partir de:</span>
                    <span class="value">R$ {{ price }}</span>
                    <span style="font-size: 0.85rem; color: #999;">{{ price_cond }}</span>
                </div>

                {% set wa_message = "Olá! Gostaria de comprar o pacote: " + title %}
                <a href="https://wa.me/{{ settings.whatsapp }}?text={{ wa_message | urlencode }}" class="btn-comprar">
                    COMPRAR
                </a>

                <div style="text-align: center; margin-top: 25px;">
                    <a href="https://wa.me/{{ settings.whatsapp }}" style="text-decoration: none; color: #333; font-weight: 500; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; gap: 8px;">
                        <i class="fa-brands fa-whatsapp" style="color: var(--success-green); font-size: 1.2rem;"></i> Precisa de ajuda? Clique aqui
                    </a>
                </div>
            </div>
        </aside>
    </main>

    <footer class="footer-premium">
        <div class="container-wide" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px;">
            <div>
                <h3 style="margin-bottom: 20px;">Sua confiança é o que nos move</h3>
                <div style="display: flex; gap: 15px; font-size: 1.5rem;">
                    <i class="fa-brands fa-instagram"></i>
                    <i class="fa-brands fa-facebook-f"></i>
                    <i class="fa-brands fa-whatsapp"></i>
                </div>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; color: #999; text-transform: uppercase; margin-bottom: 20px;">Pacotes</h4>
                <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                    <li style="margin-bottom: 10px;">Aéreos</li>
                    <li style="margin-bottom: 10px;">Rodoviários</li>
                    <li style="margin-bottom: 10px;">Cruzeiros</li>
                </ul>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; color: #999; text-transform: uppercase; margin-bottom: 20px;">Serviços</h4>
                <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                    <li style="margin-bottom: 10px;">Vistos</li>
                    <li style="margin-bottom: 10px;">Passaportes</li>
                    <li style="margin-bottom: 10px;">Seguro Viagem</li>
                </ul>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; color: #999; text-transform: uppercase; margin-bottom: 20px;">Contato</h4>
                <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                    <li style="margin-bottom: 10px;"><i class="fa-solid fa-phone"></i> {{ settings.whatsapp }}</li>
                    <li style="margin-bottom: 10px;"><i class="fa-solid fa-envelope"></i> contato@francelinoturismo.com.br</li>
                </ul>
            </div>
        </div>
        <div style="text-align: center; margin-top: 60px; font-size: 0.8rem; color: #BBB;">
            © 2026 - Francelino Turismo. Todos os direitos reservados.
        </div>
    </footer>

</body>
</html>
