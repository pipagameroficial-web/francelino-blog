<!DOCTYPE html>
<html lang="pt-BR">
<head>
    {% if settings.gtm_id %}
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','{{ settings.gtm_id }}');</script>
    <!-- End Google Tag Manager -->
    {% endif %}

    {% if settings.google_analytics_id %}
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.google_analytics_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.google_analytics_id }}');
    </script>
    <!-- End Google Analytics -->
    {% endif %}

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Francelino Turismo</title>
    <link rel="stylesheet" href="/agencia-style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        .package-detail-hero {
            position: relative;
            height: 50vh;
            min-height: 400px;
            background-image: url('{{ image }}');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: flex-end;
            color: white;
            padding-bottom: 50px;
        }
        
        .package-detail-hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        }
        
        .hero-container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        .package-content-grid {
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 40px;
            margin-top: -60px;
            position: relative;
            z-index: 10;
        }
        
        .package-main-card {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        
        .package-sidebar {
            position: sticky;
            top: 100px;
        }
        
        .booking-card {
            background: #0E487B;
            color: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(14, 72, 123, 0.2);
        }
        
        .booking-card .price-value {
            font-size: 2.5rem;
            color: #F89C1D;
            display: block;
            margin: 10px 0;
        }
        
        .itinerary-content {
            margin-top: 30px;
            line-height: 1.8;
            font-size: 1.1rem;
        }
        
        .itinerary-content h2, .itinerary-content h3 {
            margin: 25px 0 15px;
            color: #0E487B;
        }
        
        .package-info-tags {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .info-tag {
            background: #f1f5f9;
            padding: 8px 15px;
            border-radius: 50px;
            font-size: 0.9rem;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: white;
            background: rgba(255,255,255,0.2);
            padding: 8px 15px;
            border-radius: 5px;
            margin-bottom: 20px;
            backdrop-filter: blur(5px);
        }

        @media (max-width: 992px) {
            .package-content-grid {
                grid-template-columns: 1fr;
            }
            .package-sidebar {
                position: static;
            }
        }
    </style>
</head>
<body>

    <!-- Header Simples -->
    <header class="header" style="position: static; background: #26211E;">
        <div class="header-dark-content" style="max-width: 1200px; margin: 0 auto; color: white;">
            <a href="/" class="logo-new">
                <div class="logo-text">
                    <span>FRANCELINO</span> TURISMO<br>
                    <small>| AGÊNCIA DE VIAGENS</small>
                </div>
            </a>
            <a href="/" style="color: white;"><i class="fa-solid fa-house"></i> Voltar ao Início</a>
        </div>
    </header>

    <div class="package-detail-hero">
        <div class="hero-container">
            <a href="/#pacotes" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Todos os Pacotes</a>
            <h1>{{ title }}</h1>
        </div>
    </div>

    <div class="container" style="margin-top: 50px; margin-bottom: 100px;">
        <div class="package-content-grid">
            <div class="package-main-card">
                <div class="package-info-tags">
                    <div class="info-tag"><i class="fa-regular fa-calendar"></i> {{ date_range }}</div>
                    <div class="info-tag"><i class="fa-solid fa-clock"></i> {{ duration }}</div>
                    {% if location %}
                    <div class="info-tag"><i class="fa-solid fa-location-dot"></i> {{ location }}</div>
                    {% endif %}
                    {% if itinerary %}
                    <div class="info-tag"><i class="fa-solid fa-ship"></i> {{ itinerary }}</div>
                    {% endif %}
                </div>

                <div class="itinerary-content">
                    {{ content | safe }}
                    
                    {% if not content %}
                    <p>Este pacote ainda não possui um roteiro detalhado cadastrado. Por favor, entre em contato para mais informações.</p>
                    {% endif %}
                </div>
            </div>

            <div class="package-sidebar">
                <div class="booking-card">
                    <span style="font-size: 1rem; opacity: 0.8;">A partir de</span>
                    <span class="price-value">R$ {{ price }}</span>
                    <p style="font-size: 0.9rem; margin-bottom: 25px; opacity: 0.9;">{{ price_cond }}</p>
                    
                    {% set wa_message = "Olá! Gostaria de fazer uma reserva para o pacote: " + title %}
                    <a href="https://wa.me/{{ settings.whatsapp }}?text={{ wa_message | urlencode }}" class="btn btn-primary btn-full" style="padding: 18px; font-size: 1.1rem; background-color: #F89C1D; color: white;">
                        <i class="fa-brands fa-whatsapp"></i> RESERVAR AGORA
                    </a>
                    
                    <p style="text-align: center; font-size: 0.8rem; margin-top: 15px; opacity: 0.7;">
                        Dúvidas? Chame nosso time no WhatsApp
                    </p>
                </div>

                <div style="margin-top: 30px; padding: 25px; background: #f8fafc; border-radius: 15px; border: 1px solid #e2e8f0;">
                    <h4 style="margin-bottom: 15px; color: #0E487B;">O que está incluso?</h4>
                    <ul style="font-size: 0.9rem; color: #64748b;">
                        <li style="margin-bottom: 8px;"><i class="fa-solid fa-check" style="color: #22c55e;"></i> Suporte Francelino Turismo</li>
                        <li style="margin-bottom: 8px;"><i class="fa-solid fa-check" style="color: #22c55e;"></i> Guia especializado</li>
                        <li style="margin-bottom: 8px;"><i class="fa-solid fa-check" style="color: #22c55e;"></i> Seguro Viagem (Opcional)</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer Simples -->
    <footer class="footer" style="padding: 50px 0 20px;">
        <div class="container" style="text-align: center;">
            <p>&copy; 2026 Francelino Turismo Agência de Viagens</p>
            <p style="font-size: 0.8rem; margin-top: 10px; opacity: 0.6;">Av. das Viagens, 1234 - Centro</p>
        </div>
    </footer>

</body>
</html>
