<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Francelino Turismo</title>
    
    <link rel="stylesheet" href="/agencia-style.css?v=4.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary-navy: #1A1A1A;
            --accent-orange: #F89C1D;
            --success-green: #00D136;
            --bg-gray: #F4F7F6;
            --text-gray: #666666;
            --white: #FFFFFF;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-gray);
            margin: 0;
            color: #333;
        }

        .header-top {
            background: #1A1A1A;
            color: white;
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .container-wide {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .main-layout {
            max-width: 1200px;
            margin: 40px auto;
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 40px;
            padding: 0 20px;
        }

        /* Premium Gallery Layout */
        .gallery-container {
            padding: 0;
            margin: 0;
            background: #FFFFFF;
        }

        .premium-gallery {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 12px;
            margin: 15px 0 10px;
        }

        /* Mosaic Layout only for 6+ items */
        .premium-gallery.has-6-plus {
            grid-template-areas: 
                "main main side1"
                "main main side2"
                "bot1 bot2 bot3";
            grid-template-columns: 1fr 1fr 1fr;
            grid-template-rows: repeat(3, 220px);
        }

        .gallery-item {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            background: #eee;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            transition: transform 0.3s ease;
            opacity: 0;
            transform: translateY(20px);
        }

        .gallery-item.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .gallery-item:hover img {
            transform: scale(1.05);
        }

        .gallery-item::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0);
            transition: background 0.3s ease;
        }

        .gallery-item:hover::after {
            background: rgba(0,0,0,0.15);
        }

        .has-6-plus .item-0 { grid-area: main; }
        .has-6-plus .item-1 { grid-area: side1; }
        .has-6-plus .item-2 { grid-area: side2; }
        .has-6-plus .item-3 { grid-area: bot1; }
        .has-6-plus .item-4 { grid-area: bot2; }
        .has-6-plus .item-5 { grid-area: bot3; }
        .has-6-plus .item-6 { grid-area: bot4; }
        .has-6-plus .item-7 { grid-area: bot5; }
        .has-6-plus .item-8 { grid-area: bot6; }

        /* General grid items if not mosaic */
        .premium-gallery:not(.has-6-plus) .gallery-item {
            aspect-ratio: 16/9;
        }

        .more-photos-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 1.2rem;
            z-index: 2;
        }

        /* Lightbox Styles */
        .lightbox-modal {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #111;
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            flex-direction: column;
        }

        .lightbox-content {
            max-width: 90%;
            max-height: 80%;
            position: relative;
        }

        .lightbox-content img {
            max-width: 100%;
            max-height: 80vh;
            border-radius: 8px;
            object-fit: contain;
        }

        .lightbox-close {
            position: absolute;
            top: 20px; right: 30px;
            color: white;
            font-size: 2.5rem;
            cursor: pointer;
            z-index: 10000;
        }

        .lightbox-nav {
            position: absolute;
            top: 50%; width: 100%;
            display: flex;
            justify-content: space-between;
            padding: 0 20px;
            transform: translateY(-50%);
            pointer-events: none;
        }

        .lightbox-nav i {
            color: white;
            font-size: 3rem;
            cursor: pointer;
            pointer-events: auto;
            opacity: 0.7;
            transition: opacity 0.3s;
        }

        .lightbox-nav i:hover { opacity: 1; }

        @media (max-width: 992px) {
            .main-layout { grid-template-columns: 1fr; }
            
            /* Mobile Carousel */
            .premium-gallery {
                display: flex;
                overflow-x: scroll;
                scroll-snap-type: x mandatory;
                gap: 15px;
                padding: 0 20px 20px;
                margin: 25px -20px 40px;
                grid-template-areas: none;
                grid-template-columns: none;
                grid-template-rows: none;
                scrollbar-width: none;
            }

            .premium-gallery::-webkit-scrollbar { display: none; }

            .gallery-item {
                flex: 0 0 85%;
                scroll-snap-align: start;
                height: 350px;
                opacity: 1 !important;
                transform: none !important;
            }

            .gallery-item:last-child {
                margin-right: 20px;
            }
        }

        /* Sidebar Info Box */
        .info-sidebar {
            background: white;
            border-radius: 20px;
            padding: 35px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            position: sticky;
            top: 100px;
        }

        .date-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 1px solid #EEE;
        }

        .date-item span {
            display: block;
            font-size: 0.75rem;
            color: #999;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .date-item strong {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }

        .price-section {
            margin: 30px 0;
        }

        .price-section .label { font-size: 0.9rem; color: #666; }
        .price-section .value { 
            display: block; 
            font-size: 2.2rem; 
            font-weight: 800; 
            color: #1A1A1A; 
            margin: 5px 0;
        }

        .btn-comprar {
            display: block;
            background: var(--success-green);
            color: white;
            text-align: center;
            padding: 20px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.2rem;
            transition: transform 0.2s ease, background 0.2s ease;
        }

        .btn-comprar:hover {
            transform: translateY(-3px);
            background: #00B52F;
        }

        /* Pagamento Section */
        .payment-section {
            margin: 25px 0;
            padding-top: 20px;
            border-top: 1px solid #EEE;
        }

        .payment-section h4 {
            font-size: 0.85rem;
            text-transform: uppercase;
            color: #999;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .payment-section h4 i {
            color: var(--accent-orange);
        }

        .payment-content {
            font-size: 0.95rem;
            line-height: 1.6;
            color: #333;
        }

        .payment-content p { margin: 0 0 10px; }
        .payment-content strong { color: var(--primary-navy); }

        /* Refinamento das listas de pagamento */
        .payment-content ul {
            list-style: none !important;
            padding: 0 !important;
            margin: 15px 0 0 !important;
        }

        .payment-content ul li {
            position: relative;
            padding-left: 28px !important;
            margin-bottom: 12px;
            font-size: 0.95rem;
            color: #444;
            line-height: 1.5;
        }

        .payment-content ul li::before {
            content: "\f00c";
            font-family: "Font Awesome 6 Free";
            font-weight: 900;
            position: absolute;
            left: 0;
            top: 2px;
            color: var(--success-green);
            font-size: 0.85rem;
        }

        /* Nova Grid de Informações Extras */
        .extra-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 0 0 40px;
        }

        .info-card-premium {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.03);
            display: flex;
            flex-direction: column;
            border: 1px solid #F0F0F0;
        }

        .info-card-premium h4 {
            font-size: 1.1rem;
            margin: 0 0 15px;
            color: var(--primary-navy);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-card-premium h4 i { color: var(--accent-orange); }

        /* Estilo Organizado de Pagamento */
        .payment-list-organized {
            list-style: none;
            padding: 0;
            margin: 0;
            font-size: 0.95rem;
        }

        .payment-list-organized li {
            padding: 10px 0;
            border-bottom: 1px dashed #EEE;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }

        .payment-list-organized li:last-child { border: none; }

        /* Instagram Card */
        .instagram-card {
            background: linear-gradient(45deg, #f09433 0%,#e6683c 25%,#dc2743 50%,#cc2366 75%,#bc1888 100%);
            color: white;
            border: none;
        }

        .instagram-card h4 { color: white; }
        .instagram-card h4 i { color: white; }

        .btn-instagram {
            margin-top: auto;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(5px);
            color: white;
            text-align: center;
            padding: 12px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
        }

        .btn-instagram:hover {
            background: white;
            color: #cc2366;
        }

        .itinerary-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            margin-bottom: 40px;
        }

        .footer-premium {
            background: #FFFFFF;
            padding: 80px 0 40px;
            border-top: 1px solid #EEE;
            margin-top: 80px;
        }

            /* Final check for mobile grid override */
            .gallery-container { padding: 20px 0 10px; }
        }
    </style>
</head>
<body>

    <header class="header-top">
        <div class="container-wide">
            <a href="/" style="color: white; text-decoration: none; font-weight: 800; font-size: 1.4rem;">
                FRANCELINO <span style="color: var(--accent-orange);">TURISMO</span>
            </a>
            <div style="display: flex; gap: 20px; align-items: centre;">
                <div style="background: rgba(255,255,255,0.1); padding: 8px 20px; border-radius: 50px; font-size: 0.9rem;">
                    Buscar destino... <i class="fa-solid fa-magnifying-glass"></i>
                </div>
                <a href="https://wa.me/{{ settings.whatsapp }}" style="color: white; font-size: 1.5rem;"><i class="fa-brands fa-whatsapp"></i></a>
            </div>
        </div>
    </header>

    <main class="main-layout">
        <div class="content-main">
            <div style="font-size: 0.85rem; color: #999; margin-bottom: 20px;">
                Home • Pacotes • {{ category | default('Nacional') }}
            </div>
            
            <h1 style="font-size: 2.5rem; margin-bottom: 10px;">{{ title }}</h1>
            <div style="background: #1A1A1A; color: white; display: inline-block; padding: 4px 15px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">
                <i class="fa-solid fa-tags"></i> {{ category | default('Nacional') }}
            </div>

            <div class="gallery-container">
                {# Robustly determine the gallery list #}
                {% set gallery_list = [] %}
                {% if gallery | is_array %}
                    {% set gallery_list = gallery %}
                {% else %}
                    {# Fallback to old img1-6 format if exists #}
                    {% set g_items = [gallery.img1, gallery.img2, gallery.img3, gallery.img4, gallery.img5, gallery.img6] %}
                    {# Using a temporary dummy loop to filter not empty items because of Nunjucks set push limitations #}
                    {% for g_img in g_items %}
                        {% if g_img %}
                            {% set gallery_list = gallery_list.concat([g_img]) %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                <div class="premium-gallery {{ 'has-6-plus' if gallery_list.length >= 6 }}" id="premium-gallery">
                    {% for item in gallery_list %}
                        {% set img_url = item.image if item.image else item %}
                        <div class="gallery-item item-{{ loop.index0 }}" data-index="{{ loop.index0 }}">
                            {% if loop.index0 == 5 and gallery_list.length > 6 %}
                                <div class="more-photos-overlay">+{{ gallery_list.length - 6 }} fotos</div>
                            {% endif %}
                            <img src="{{ img_url | optimize_unsplash(800) }}" alt="Foto {{ loop.index }}" loading="lazy">
                        </div>
                    {% endfor %}
                </div>
            </div>

            <div class="extra-info-grid" style="grid-template-columns: 1fr;">
                <!-- Card de Instagram (Agora com conteúdo REAL do perfil) -->
                <div class="info-card-premium instagram-card" style="flex-direction: column; align-items: flex-start; justify-content: flex-start; gap: 20px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div style="width: 45px; height: 45px; border-radius: 50%; border: 2px solid white; overflow: hidden;">
                                <img src="{{ image }}" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>
                            <div>
                                <h4 style="margin: 0; font-size: 1rem;"><i class="fa-brands fa-instagram"></i> @francelino_turismo_oficial</h4>
                                <span style="font-size: 0.7rem; opacity: 0.9;">Atualizado recentemente</span>
                            </div>
                        </div>
                        <a href="https://instagram.com/francelino_turismo_oficial/" target="_blank" class="btn-instagram" style="margin: 0; padding: 8px 15px; font-size: 0.8rem;">
                            SEGUIR
                        </a>
                    </div>

                    <div style="background: rgba(255,255,255,0.1); padding: 12px; border-radius: 12px; font-size: 0.85rem; line-height: 1.4;">
                        <strong>Último post:</strong> "Vai comprar no Paraguai pela primeira vez? 🇵🇾 Então salva este post, porque essas dicas evitam dor de cabeça!..."
                    </div>

                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; width: 100%;">
                        <a href="https://www.instagram.com/reel/DSmptEtDuOf/" target="_blank" style="aspect-ratio: 1/1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.2);">
                            <img src="/assets/instagram/ig1.jpg" style="width: 100%; height: 100%; object-fit: cover;">
                        </a>
                        <a href="https://www.instagram.com/reel/DDdR9RAvJ_B/" target="_blank" style="aspect-ratio: 1/1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.2);">
                            <img src="/assets/instagram/ig2.jpg" style="width: 100%; height: 100%; object-fit: cover;">
                        </a>
                        <a href="https://www.instagram.com/reel/DWFKZZ2gBJS/" target="_blank" style="aspect-ratio: 1/1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.2);">
                            <img src="/assets/instagram/ig3.jpg" style="width: 100%; height: 100%; object-fit: cover;">
                        </a>
                        <a href="https://www.instagram.com/reel/DDs-G19gV95/" target="_blank" style="aspect-ratio: 1/1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.2);">
                            <img src="/assets/instagram/ig4.jpg" style="width: 100%; height: 100%; object-fit: cover;">
                        </a>
                        <a href="https://www.instagram.com/reel/DDp8_J9gg5v/" target="_blank" style="aspect-ratio: 1/1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.2);">
                            <img src="/assets/instagram/ig5.jpg" style="width: 100%; height: 100%; object-fit: cover;">
                        </a>
                        <a href="https://www.instagram.com/reel/DDks1RcAatx/" target="_blank" style="aspect-ratio: 1/1; border-radius: 8px; overflow: hidden; border: 1px solid rgba(255,255,255,0.2);">
                            <img src="/assets/instagram/ig6.jpg" style="width: 100%; height: 100%; object-fit: cover;">
                        </a>
                    </div>
                </div>
            </div>

            <div class="itinerary-card">
                <h2>Detalhes do Pacote</h2>
                <div class="itinerary-content">
                    {{ content | safe }}
                </div>
            </div>
        </div>

        <aside class="sidebar-info">
            <div class="info-sidebar">
                <h3 style="margin-top: 0; font-size: 1.4rem; margin-bottom: 25px;">Informações</h3>
                
                <div class="date-row">
                    <div class="date-item">
                        <span>SAÍDA</span>
                        <strong><i class="fa-regular fa-calendar" style="color: var(--accent-orange);"></i> {{ dates.departure | default('Consultar') }}</strong>
                    </div>
                    <div class="date-item">
                        <span>RETORNO</span>
                        <strong><i class="fa-regular fa-calendar" style="color: var(--accent-orange);"></i> {{ dates.return | default('Consultar') }}</strong>
                    </div>
                </div>

                <div class="price-section">
                    <span class="label">A partir de:</span>
                    <span class="value">R$ {{ price }}</span>
                    <span style="font-size: 0.85rem; color: #999;">{{ price_cond }}</span>
                </div>

                {% set wa_message = "Olá! Gostaria de comprar o pacote: " + title %}
                <a href="https://wa.me/{{ settings.whatsapp }}?text={{ wa_message | urlencode }}" class="btn-comprar">
                    COMPRAR
                </a>

                <div style="text-align: center; margin-top: 25px;">
                    <a href="https://wa.me/{{ settings.whatsapp }}" style="text-decoration: none; color: #333; font-weight: 500; font-size: 0.9rem; display: flex; align-items: center; justify-content: center; gap: 8px;">
                        <i class="fa-brands fa-whatsapp" style="color: var(--success-green); font-size: 1.2rem;"></i> Precisa de ajuda? Clique aqui
                    </a>
                </div>

                {% if payment_conditions %}
                <div class="payment-section" style="margin-top: 25px; border-top: 1px solid #EEE; padding-top: 20px;">
                    <h4 style="font-size: 0.85rem; text-transform: uppercase; color: #999; margin-bottom: 15px; display: flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-credit-card" style="color: var(--accent-orange);"></i> Formas de Pagamento
                    </h4>
                    <div class="payment-content">
                        {{ payment_conditions | safe }}
                    </div>
                </div>
                {% endif %}
            </div>
        </aside>
    </main>

    <footer class="footer-premium">
        <div class="container-wide" style="display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px;">
            <div>
                <h3 style="margin-bottom: 20px;">Sua confiança é o que nos move</h3>
                <div style="display: flex; gap: 15px; font-size: 1.5rem;">
                    <i class="fa-brands fa-instagram"></i>
                    <i class="fa-brands fa-facebook-f"></i>
                    <i class="fa-brands fa-whatsapp"></i>
                </div>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; color: #999; text-transform: uppercase; margin-bottom: 20px;">Pacotes</h4>
                <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                    <li style="margin-bottom: 10px;">Aéreos</li>
                    <li style="margin-bottom: 10px;">Rodoviários</li>
                    <li style="margin-bottom: 10px;">Cruzeiros</li>
                </ul>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; color: #999; text-transform: uppercase; margin-bottom: 20px;">Serviços</h4>
                <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                    <li style="margin-bottom: 10px;">Vistos</li>
                    <li style="margin-bottom: 10px;">Passaportes</li>
                    <li style="margin-bottom: 10px;">Seguro Viagem</li>
                </ul>
            </div>
            <div>
                <h4 style="font-size: 0.8rem; color: #999; text-transform: uppercase; margin-bottom: 20px;">Contato</h4>
                <ul style="list-style: none; padding: 0; font-size: 0.9rem;">
                    <li style="margin-bottom: 10px;"><i class="fa-solid fa-phone"></i> {{ settings.whatsapp }}</li>
                    <li style="margin-bottom: 10px;"><i class="fa-solid fa-envelope"></i> contato@francelinoturismo.com.br</li>
                </ul>
            </div>
        </div>
        <div style="text-align: center; margin-top: 60px; font-size: 0.8rem; color: #BBB;">
            © 2026 - Francelino Turismo. Todos os direitos reservados.
        </div>
    </footer>

    </div>

    <!-- Premium Lightbox Structure -->
    <div class="lightbox-modal" id="lightbox">
        <span class="lightbox-close" id="lightbox-close">&times;</span>
        <div class="lightbox-nav">
            <i class="fa-solid fa-chevron-left" id="prev-img"></i>
            <i class="fa-solid fa-chevron-right" id="next-img"></i>
        </div>
        <div class="lightbox-content">
            <img src="" id="lightbox-img" alt="Fullscreen picture">
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const gallery = document.getElementById('premium-gallery');
            const items = gallery.querySelectorAll('.gallery-item');
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img');
            const closeBtn = document.getElementById('lightbox-close');
            const prevBtn = document.getElementById('prev-img');
            const nextBtn = document.getElementById('next-img');
            
            let currentIndex = 0;
            const images = Array.from(items).map(item => item.querySelector('img').src);

            // Scroll Animation (Fade + Slide Up) with consistent cascade
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        const index = entry.target.getAttribute('data-index');
                        setTimeout(() => {
                            entry.target.classList.add('visible');
                        }, index * 100);
                    }
                });
            }, { threshold: 0.1 });

            items.forEach(item => observer.observe(item));

            // Lightbox Logic
            const openLightbox = (index) => {
                currentIndex = index;
                updateLightbox();
                lightbox.style.display = 'flex';
                document.body.style.overflow = 'hidden';
            };

            const updateLightbox = () => {
                lightboxImg.src = images[currentIndex];
            };

            items.forEach((item, index) => {
                item.addEventListener('click', () => openLightbox(index));
            });

            closeBtn.addEventListener('click', () => {
                lightbox.style.display = 'none';
                document.body.style.overflow = 'auto';
            });

            const nextImg = () => {
                currentIndex = (currentIndex + 1) % images.length;
                updateLightbox();
            };

            const prevImg = () => {
                currentIndex = (currentIndex - 1 + images.length) % images.length;
                updateLightbox();
            };

            nextBtn.addEventListener('click', (e) => { e.stopPropagation(); nextImg(); });
            prevBtn.addEventListener('click', (e) => { e.stopPropagation(); prevImg(); });

            // Keyboard Navigation
            document.addEventListener('keydown', (e) => {
                if (lightbox.style.display === 'flex') {
                    if (e.key === 'ArrowRight') nextImg();
                    if (e.key === 'ArrowLeft') prevImg();
                    if (e.key === 'Escape') closeBtn.click();
                }
            });

            // Swipe logic for mobile (Simple version)
            let touchStartX = 0;
            let touchEndX = 0;
            
            lightbox.addEventListener('touchstart', e => touchStartX = e.changedTouches[0].screenX);
            lightbox.addEventListener('touchend', e => {
                touchEndX = e.changedTouches[0].screenX;
                if (touchEndX < touchStartX - 50) nextImg();
                if (touchEndX > touchStartX + 50) prevImg();
            });
        });
    </script>

</body>
</html>
