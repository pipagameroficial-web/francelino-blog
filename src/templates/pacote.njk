<!DOCTYPE html>
<html lang="pt-BR">
<head>
    {% if settings.gtm_id %}
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&lLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','{{ settings.gtm_id }}');</script>
    <!-- End Google Tag Manager -->
    {% endif %}

    {% if settings.google_analytics_id %}
    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.google_analytics_id }}"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', '{{ settings.google_analytics_id }}');
    </script>
    <!-- End Google Analytics -->
    {% endif %}

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | Francelino Turismo</title>
    
    <!-- CSS Global -->
    <link rel="stylesheet" href="/agencia-style.css?v=2.0">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.85);
            --glass-border: rgba(255, 255, 255, 0.18);
            --navy: #0E487B;
            --orange: #F89C1D;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
            color: #1e293b;
            margin: 0;
            padding: 0;
        }

        .premium-nav {
            background: rgba(38, 33, 30, 0.95);
            backdrop-filter: blur(10px);
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .nav-logo-text {
            color: white;
            font-weight: 800;
            font-size: 1.2rem;
            letter-spacing: 1px;
            text-decoration: none;
        }

        .nav-logo-text span { color: var(--orange); }

        .package-hero {
            height: 60vh;
            min-height: 500px;
            background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.7)), url('{{ image }}');
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
        }

        .hero-content h1 {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 20px;
            text-shadow: 0 4px 15px rgba(0,0,0,0.5);
            max-width: 900px;
            padding: 0 20px;
        }

        .breadcrumb {
            display: flex;
            gap: 10px;
            justify-content: center;
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 15px;
        }

        .main-grid {
            max-width: 1200px;
            margin: -80px auto 100px;
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 30px;
            padding: 0 20px;
            position: relative;
            z-index: 10;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.06);
        }

        .sidebar-card {
            background: var(--navy);
            border-radius: 24px;
            padding: 35px;
            color: white;
            position: sticky;
            top: 100px;
            box-shadow: 0 20px 40px rgba(14, 72, 123, 0.25);
        }

        .info-strip {
            display: flex;
            gap: 25px;
            margin-bottom: 35px;
            padding-bottom: 25px;
            border-bottom: 1px solid #e2e8f0;
            flex-wrap: wrap;
        }

        .info-item {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
            color: #64748b;
        }

        .info-item i {
            font-size: 1.2rem;
            color: var(--navy);
        }

        .itinerary-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .itinerary-title::after {
            content: '';
            flex: 1;
            height: 2px;
            background: #e2e8f0;
        }

        .itinerary-body {
            line-height: 1.8;
            font-size: 1.15rem;
            color: #334155;
        }

        .itinerary-body ul {
            list-style: none;
            padding: 0;
        }

        .itinerary-body li {
            position: relative;
            padding-left: 30px;
            margin-bottom: 15px;
        }

        .itinerary-body li::before {
            content: '\f058';
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            left: 0;
            color: var(--orange);
        }

        .price-tag {
            background: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
            text-align: center;
        }

        .price-label { font-size: 0.9rem; opacity: 0.8; }
        .price-amount { 
            font-size: 2.8rem; 
            font-weight: 800; 
            color: var(--orange); 
            display: block;
            margin: 5px 0;
        }

        .btn-booking {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: var(--orange);
            color: white;
            text-decoration: none;
            padding: 20px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.2rem;
            transition: transform 0.3s ease, background 0.3s ease;
            box-shadow: 0 10px 20px rgba(248, 156, 29, 0.3);
        }

        .btn-booking:hover {
            transform: translateY(-3px);
            background: #e08b15;
        }

        .features-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 40px;
        }

        .feature-box {
            background: white;
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            border: 1px solid #e2e8f0;
        }

        .feature-box i {
            font-size: 1.5rem;
            color: var(--navy);
            margin-bottom: 10px;
        }

        .feature-box h4 { margin: 0; font-size: 0.9rem; }

        @media (max-width: 992px) {
            .main-grid { grid-template-columns: 1fr; margin-top: -40px; }
            .hero-content h1 { font-size: 2.2rem; }
            .sidebar-card { position: static; }
        }
    </style>
</head>
<body>

    <nav class="premium-nav">
        <div class="nav-container">
            <a href="/" class="nav-logo-text"><span>FRANCELINO</span> TURISMO</a>
            <a href="/" style="color: white; text-decoration: none; font-weight: 500;"><i class="fa-solid fa-arrow-left"></i> Voltar</a>
        </div>
    </nav>

    <div class="package-hero">
        <div class="hero-content">
            <div class="breadcrumb">
                <span>Início</span> / <span>Pacotes</span> / <span>{{ title }}</span>
            </div>
            <h1>{{ title }}</h1>
        </div>
    </div>

    <main class="main-grid">
        <div class="glass-card">
            <div class="info-strip">
                <div class="info-item"><i class="fa-regular fa-calendar-check"></i> {{ date_range }}</div>
                <div class="info-item"><i class="fa-solid fa-hourglass-half"></i> {{ duration }}</div>
                {% if location %}
                <div class="info-item"><i class="fa-solid fa-map-location-dot"></i> {{ location }}</div>
                {% endif %}
                {% if itinerary %}
                <div class="info-item"><i class="fa-solid fa-ship"></i> {{ itinerary }}</div>
                {% endif %}
            </div>

            <h2 class="itinerary-title"><i class="fa-solid fa-route"></i> Roteiro Completo</h2>
            
            <div class="itinerary-body">
                {{ content | safe }}
                
                {% if not content %}
                <p>Nossa equipe está finalizando os detalhes deste roteiro. Entre em contato para receber o itinerário em PDF de forma antecipada!</p>
                {% endif %}
            </div>

            <div class="features-grid">
                <div class="feature-box">
                    <i class="fa-solid fa-shield-halved"></i>
                    <h4>Seguro Viagem</h4>
                </div>
                <div class="feature-box">
                    <i class="fa-solid fa-headset"></i>
                    <h4>Suporte 24h</h4>
                </div>
                <div class="feature-box">
                    <i class="fa-solid fa-bus"></i>
                    <h4>Transporte VIP</h4>
                </div>
                <div class="feature-box">
                    <i class="fa-solid fa-star"></i>
                    <h4>Guia Experiente</h4>
                </div>
            </div>
        </div>

        <aside class="package-sidebar">
            <div class="sidebar-card">
                <div class="price-tag">
                    <span class="price-label">Valor do Investimento</span>
                    <span class="price-amount">R$ {{ price }}</span>
                    <p style="font-size: 0.9rem; opacity: 0.8; margin-top: 10px;">{{ price_cond }}</p>
                </div>

                <p style="margin-bottom: 25px; font-size: 0.95rem; line-height: 1.6; text-align: center; opacity: 0.9;">
                    Garanta sua vaga agora mesmo e parcele sua viagem em condições exclusivas. Atendimento imediato via WhatsApp.
                </p>

                {% set wa_message = "Olá! Tenho interesse no pacote: " + title + ". Gostaria de mais informações e disponibilidade." %}
                <a href="https://wa.me/{{ settings.whatsapp }}?text={{ wa_message | urlencode }}" class="btn-booking" target="_blank">
                    <i class="fa-brands fa-whatsapp"></i> FALAR COM CONSULTOR
                </a>

                <div style="margin-top: 30px; text-align: center; font-size: 0.85rem; opacity: 0.7;">
                    <i class="fa-solid fa-lock"></i> Pagamento 100% Seguro
                </div>
            </div>
        </aside>
    </main>

    <footer style="background: #26211E; color: white; padding: 60px 0 30px; text-align: center; border-top: 4px solid var(--orange);">
        <div class="container">
            <img src="/logo.png" alt="Logo" style="height: 50px; margin-bottom: 20px; filter: brightness(0) invert(1);">
            <p style="opacity: 0.7;">© 2026 Francelino Turismo. Todos os direitos reservados.</p>
        </div>
    </footer>

</body>
</html>
